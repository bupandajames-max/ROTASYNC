rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserEmail() {
      return request.auth.token.email;
    }

    // --- ROLE / SCOPE PRIMITIVES (Phase D enforcement) ---
    // The caller's tier lives in users/{uid} (written on login). Super users are
    // additionally recognized by email so seeding never depends on that doc.
    // NOTE: keep SUPER_EMAILS in sync with src/config/access.ts SUPERUSER_EMAILS.
    function callerEmail() {
      return isSignedIn() ? request.auth.token.email : '';
    }
    function isSuperEmail() {
      return callerEmail() in ['bupandajames@gmail.com'];
    }
    // Durable super-admin grants, managed in-app (see platformAdmins below).
    // isSuperEmail() stays only as the bootstrap path for the very first one.
    function isPlatformAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/platformAdmins/$(request.auth.uid));
    }
    function callerLevel() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accessLevel
        : 'staff';
    }
    // The facility this caller belongs to (from their role doc). Super users have none.
    function callerFacility() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.facilityId
        : '';
    }
    // The organization this caller belongs to. Uses .get() with a default
    // (not dot access) because organizationId is a new field — existing
    // users/{uid} docs written before this field existed don't have it, and
    // dot-accessing a missing map key errors rather than returning null.
    function callerOrganization() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('organizationId', '')
        : '';
    }
    // The department this caller belongs to. Used for genuine department-
    // level READ isolation (not just a client-side UI filter) below — a
    // Member or Supervisor in one department must not be able to read
    // another department's staff/timesheet records even via direct API
    // access, only via the UI's own "show all" toggle. Facility-level+
    // callers (Manager/Org Admin/Super) always see the whole facility
    // regardless of this value — see isFacilityLevel() branches below.
    function callerDepartment() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('departmentId', '')
        : '';
    }
    // Per-tenant write isolation: a non-super user may only write within their facility.
    function inMyFacility(fid) {
      return isSuper() || fid == callerFacility();
    }
    function isSuper() {
      return isSignedIn() && (isSuperEmail() || isPlatformAdmin() || callerLevel() == 'superuser');
    }
    function isFacilityLevel() {
      return isSignedIn() && (isSuper() || callerLevel() == 'facility_manager');
    }
    function isManagerLevel() {
      return isSignedIn() && (isFacilityLevel() || callerLevel() == 'dept_head');
    }

    // Standard string sanitization check to prevent path/injection poisoning
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Helper functions for collection schemas
    function isValidFacility(data) {
      return data.keys().hasAll(['id', 'name', 'location'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 150
        && data.location is string && data.location.size() <= 150
        // Org-defined classification (e.g. 'Branch', 'Warehouse', 'Primary Care')
        // — free text per workspace, not a fixed clinical enum.
        && (!data.keys().contains('facilitiesType') || (data.facilitiesType is string && data.facilitiesType.size() <= 100))
        // Owning Organization — optional so pre-existing facilities (written
        // before this field existed) still validate.
        && (!data.keys().hasAny(['organizationId']) || (data.organizationId is string && data.organizationId.size() <= 128));
    }

    function isValidOrganization(data) {
      return data.keys().hasAll(['id', 'name', 'ownerUid', 'createdAt'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 150
        && data.ownerUid is string && data.ownerUid.size() > 0
        && data.createdAt is string;
    }

    // Bootstrap allowance for a brand-new user self-creating their users/{uid}
    // doc at 'facility_manager' the moment they finish SetupWizard: only
    // valid when they already own the referenced organization AND that
    // organization already owns the referenced facility (both docs must
    // already exist — see handleCompleteSetup's write order in App.tsx).
    function isOrgBootstrap(data) {
      return data.accessLevel == 'facility_manager'
        && data.organizationId is string && data.organizationId.size() > 0
        && data.facilityId is string && data.facilityId.size() > 0
        && exists(/databases/$(database)/documents/organizations/$(data.organizationId))
        && get(/databases/$(database)/documents/organizations/$(data.organizationId)).data.ownerUid == request.auth.uid
        && exists(/databases/$(database)/documents/facilities/$(data.facilityId))
        && get(/databases/$(database)/documents/facilities/$(data.facilityId)).data.get('organizationId', '') == data.organizationId;
    }

    // --- INVITES ---
    // The only path into an EXISTING facility (see staff/{staffId}'s
    // isSelfOnboardStaff below). Doc ID is deterministic — facilityId + '--'
    // + email — so both the client and these rules can look one up directly
    // by (facilityId, email) with get()/exists() instead of a query, and so
    // the ID itself can be checked against its own content at creation time.
    function isValidInviteId(id) {
      // Includes '+' since it's a real, common character in email local
      // parts (plus-addressing, e.g. alice+test@gmail.com) — without it,
      // inviting any such address would be silently rejected here.
      return id is string && id.size() <= 300 && id.matches('^[a-zA-Z0-9_@.+\\-]+$');
    }

    function isValidInvite(data) {
      return data.keys().hasAll(['id', 'email', 'organizationId', 'facilityId', 'role', 'invitedBy', 'status', 'createdAt'])
        && data.id is string && data.id.size() <= 300
        && data.email is string && data.email.size() > 0 && data.email.size() <= 150
        && data.organizationId is string && data.organizationId.size() <= 128
        && data.facilityId is string && data.facilityId.size() <= 128
        // Never 'superuser' — that tier stays platform-admin/bootstrap-email
        // only (see isSuper()), invites can't grant it.
        && data.role in ['staff', 'dept_head', 'facility_manager']
        && data.invitedBy is string && data.invitedBy.size() <= 150
        && data.status in ['pending', 'accepted', 'revoked']
        && data.createdAt is string
        && (!data.keys().hasAny(['departmentId']) || (data.departmentId is string && data.departmentId.size() <= 128))
        && (!data.keys().hasAny(['facilityName']) || (data.facilityName is string && data.facilityName.size() <= 150))
        && (!data.keys().hasAny(['departmentName']) || (data.departmentName is string && data.departmentName.size() <= 150));
    }

    // An inviter may only grant a role at or below their own tier — mirrors
    // EnterpriseAdmin's existing assignableRoles capping exactly (only a
    // super user may appoint a facility_manager; a facility_manager or
    // dept_head may appoint a dept_head; anyone manager-level+ may appoint
    // plain staff), now also enforced server-side.
    function canGrantRole(role) {
      return role == 'staff'
        || (role == 'dept_head' && isManagerLevel())
        || (role == 'facility_manager' && isSuper());
    }

    function inviteDocPath(email, facilityId) {
      return /databases/$(database)/documents/invites/$(facilityId + '--' + email);
    }
    function inviteExists(email, facilityId) {
      return exists(inviteDocPath(email, facilityId));
    }
    // Guarded internally so callers never need their own exists() check —
    // matches this file's existing callerFacility()-style defensive pattern,
    // since get()-ing a path that doesn't exist errors out the expression.
    function inviteRoleFor(email, facilityId) {
      return inviteExists(email, facilityId) ? get(inviteDocPath(email, facilityId)).data.role : '';
    }
    function inviteStatusFor(email, facilityId) {
      return inviteExists(email, facilityId) ? get(inviteDocPath(email, facilityId)).data.status : '';
    }
    function hasUsableInvite(email, facilityId) {
      return inviteExists(email, facilityId) && inviteStatusFor(email, facilityId) != 'revoked';
    }
    // Bootstrap allowance for a brand-new user self-creating their users/{uid}
    // doc at the exact level their invite grants — mirrors isOrgBootstrap's
    // shape, gated on the same invite the staff self-create rule checks.
    function inviteGrantsLevel(email, facilityId, level) {
      return hasUsableInvite(email, facilityId) && inviteRoleFor(email, facilityId) == level;
    }

    function isValidDepartment(data) {
      return data.keys().hasAll(['id', 'facilityId', 'name'])
        && data.id is string && data.id.size() <= 128
        && data.facilityId is string && data.facilityId.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 150;
    }

    function isValidStaff(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'role', 'facilityId'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 150
        && data.role is string && data.role.size() <= 100
        && data.facilityId is string && data.facilityId.size() <= 100;
    }

    // Self-onboarding: a signed-in user creating their OWN staff doc, joining
    // an existing facility at EXACTLY the access level a manager already
    // invited them at (see invites/{inviteId} below) — open self-signup
    // into an arbitrary facility is not allowed. accessLevel is allowed here
    // (unlike a manager-authored staff doc) only because it's pinned to
    // match the invite's role exactly, so it can't be used to self-escalate.
    function isSelfOnboardStaff(data) {
      return isValidStaff(data)
        && data.email == callerEmail()
        && hasUsableInvite(data.email, data.facilityId)
        && data.keys().hasAny(['accessLevel'])
        && data.accessLevel == inviteRoleFor(data.email, data.facilityId)
        && data.isManager == (data.accessLevel == 'facility_manager')
        && exists(/databases/$(database)/documents/facilities/$(data.facilityId));
    }

    function isValidCycle(data) {
      return data.keys().hasAll(['id', 'startDate', 'endDate', 'shifts'])
        && data.id is string && data.id.size() <= 128
        && data.startDate is string && data.startDate.size() <= 32
        && data.endDate is string && data.endDate.size() <= 32
        && data.shifts is map;
    }

    function isValidTaskMaster(data) {
      return data.keys().hasAll(['id', 'name', 'category', 'pattern', 'priority', 'frequency', 'active'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 150
        // Category is a dynamic, workspace-defined string (not a fixed clinical enum).
        && data.category is string && data.category.size() > 0 && data.category.size() <= 100
        && data.pattern in ['Shift-based', 'Role-group', 'Linked', 'Collab', 'Person-specific', 'Manager-assign', 'Dispensing-rotate', 'Auto']
        && data.priority in ['Critical', 'High', 'Standard', 'Routine']
        && data.frequency is string && data.frequency.size() <= 50
        && data.active is bool
        // Optional skill requirements, when present, must be a list.
        && (!data.keys().hasAny(['requiredSkills']) || data.requiredSkills is list);
    }

    function isValidSystemConfig(data) {
      return data.keys().hasAll(['id', 'seeded'])
        && data.id is string && data.id.size() <= 128
        && data.seeded is bool;
    }

    // Lightweight notes managers attach to a roster cell (see RosterActionItem).
    function isValidActionItem(data) {
      return data.keys().hasAll(['id', 'date', 'title', 'done', 'facilityId'])
        && data.id is string && data.id.size() <= 128
        && data.date is string && data.date.size() <= 32
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.done is bool
        && data.facilityId is string && data.facilityId.size() <= 100;
    }

    // --- COLLECTION RULES MATCH BLOCKS ---
    // Reads are open to any signed-in user (the app hydrates collections and
    // filters by facility/department client-side). Writes are role-gated.

    match /systemConfig/{configId} {
      allow read: if isSignedIn();
      allow create, update: if isManagerLevel() && isValidId(configId) && isValidSystemConfig(incoming());
      allow delete: if isManagerLevel();
    }

    // Role mirror — one doc per authenticated user, keyed by auth UID. This is
    // the doc callerLevel() reads, so it's the actual privilege choke point:
    // a user may always write their OWN doc at 'staff' (the safe default),
    // but may not self-escalate beyond that. Re-affirming a level already on
    // the doc is allowed (so an already-legitimately-elevated user's own
    // hydration write doesn't break); moving a level UP for yourself is not.
    // Granting someone a higher tier is a separate write performed by an
    // existing manager-level+ user, targeting that OTHER person's doc.
    match /users/{userId} {
      // Always allowed to read your own doc (needed before facilityId is even
      // known, e.g. right after first sign-in). Otherwise scoped to managers
      // reading within their own facility, or super users reading any.
      allow read: if isSignedIn() && (request.auth.uid == userId || isSuper()
        || (isManagerLevel() && resource.data.facilityId == callerFacility()));
      // Two additional self-create/self-update escape hatches beyond the
      // plain 'staff' default: isOrgBootstrap (the SetupWizard creator
      // becoming facility_manager of the org+facility they just made) and
      // inviteGrantsLevel (accepting an invite at exactly the level it
      // grants). Both re-verify against a separate, already-committed doc
      // the caller doesn't control (organizations/{orgId}.ownerUid or
      // invites/{id}.role), so neither can be used to self-assert an
      // arbitrary level.
      allow create: if isSignedIn() && request.auth.uid == userId
        && (incoming().accessLevel == 'staff' || isSuperEmail() || isPlatformAdmin()
            || isOrgBootstrap(incoming())
            || inviteGrantsLevel(incoming().email, incoming().facilityId, incoming().accessLevel));
      allow update: if isSignedIn() && request.auth.uid == userId
        && (incoming().accessLevel == 'staff' || incoming().accessLevel == existing().accessLevel || isSuperEmail() || isPlatformAdmin()
            || isOrgBootstrap(incoming())
            || inviteGrantsLevel(incoming().email, incoming().facilityId, incoming().accessLevel));
      allow update: if isSignedIn() && request.auth.uid != userId
        && isManagerLevel() && inMyFacility(incoming().facilityId);
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // Durable super-admin grants — one doc per platform admin, keyed by their
    // uid. Only an existing super user (email-bootstrapped or already a
    // platform admin) can grant/revoke another. This is what lets adding an
    // admin be an in-app action instead of a source-code change + redeploy.
    match /platformAdmins/{adminUid} {
      allow read: if isSuper();
      allow create, delete: if isSuper();
    }

    // Facilities (sites): readable only by members of that facility (or
    // super users) — not by any signed-in stranger. Updates remain
    // super-only. The "first-run bootstrap" create branch used to allow ANY
    // signed-in user with no facility yet (callerFacility()=='') to create
    // their own first facility — meaning any Google account at all could
    // self-provision a brand-new workspace with zero invite or approval.
    // Restricted to isSuper() so only the approved bootstrap owner(s) can
    // ever spin up a new organization/facility on this deployment; everyone
    // else must be invited into an existing one. Creating ADDITIONAL
    // facilities under an existing org remains super-only too — see
    // deferred work.
    match /facilities/{facilityId} {
      allow read: if isSuper() || facilityId == callerFacility();
      allow create: if isSuper() && isValidId(facilityId) && isValidFacility(incoming());
      allow create: if isSuper() && isValidId(facilityId) && isValidFacility(incoming())
        && incoming().organizationId is string && incoming().organizationId.size() > 0
        && exists(/databases/$(database)/documents/organizations/$(incoming().organizationId))
        && get(/databases/$(database)/documents/organizations/$(incoming().organizationId)).data.ownerUid == request.auth.uid
        && callerFacility() == '';
      allow update: if isSuper() && isValidId(facilityId) && isValidFacility(incoming());
      allow delete: if isSuper();
    }

    // Organizations: the top-level ownership/invite namespace above
    // Facility. Previously ANY signed-in user could create one they own
    // (self-serve) — meaning any Google account could bootstrap its own
    // organization on this deployment with no gate at all. This is meant to
    // be a private, single-tenant tool, not open public signup, so creation
    // is now restricted to isSuper() same as facilities above. Rate-limiting/
    // abuse prevention for repeated org creation by an approved owner is
    // still deferred, but that's a much smaller surface than "anyone at all."
    // Facility-scoped operational isolation is untouched by this: rosters,
    // tasks, timesheets, departments all still gate on facilityId, not this.
    match /organizations/{orgId} {
      allow read: if isSuper() || orgId == callerOrganization() || (isSignedIn() && resource.data.ownerUid == request.auth.uid);
      allow create: if isSuper() && isValidId(orgId) && isValidOrganization(incoming()) && incoming().ownerUid == request.auth.uid;
      // Third branch: renaming an organization (Settings -> Terminology &
      // Labels -> Organization / Company Name) is a normal facility-manager+
      // action, not an ownership change — the org name previously only lived
      // in a local-only per-facility cache for exactly this reason (nobody
      // but the bootstrap owner/superuser could write the real org doc), so
      // it never survived a reload, a new device, or a facility switch.
      // Scoped tightly: only someone already IN this org (callerOrganization()
      // match) at facility-manager+ level, and ownerUid/id must stay unchanged.
      allow update: if isSuper()
        || (isSignedIn() && resource.data.ownerUid == request.auth.uid && incoming().ownerUid == resource.data.ownerUid && isValidOrganization(incoming()))
        || (isSignedIn() && isFacilityLevel() && orgId == callerOrganization()
            && incoming().id == resource.data.id && incoming().ownerUid == resource.data.ownerUid && isValidOrganization(incoming()));
      allow delete: if isSuper();
    }

    // Invites: the only path into an EXISTING facility (see staff/{staffId}'s
    // isSelfOnboardStaff and users/{uid}'s inviteGrantsLevel above). A
    // manager creates one scoped to their own facility/org, capped to a role
    // they're allowed to grant (canGrantRole). The invitee can read it (by
    // email) before accepting, and flip it to 'accepted' themselves — no
    // other field may change on that write. A manager may revoke a pending
    // invite in their own facility. There is deliberately no "claim by
    // link" path — every read/accept is pinned to the invitee's own
    // signed-in email via callerEmail(), so an invite can't be claimed by
    // anyone it wasn't issued to.
    match /invites/{inviteId} {
      allow read: if isSuper()
        || (isSignedIn() && resource.data.email == callerEmail())
        || (isManagerLevel() && resource.data.facilityId == callerFacility());
      allow create: if isManagerLevel()
        && isValidInviteId(inviteId)
        && isValidInvite(incoming())
        && inMyFacility(incoming().facilityId)
        // A super user (org owner / platform admin) legitimately has no
        // single organization of their own, so callerOrganization() is ''
        // for them and this equality could never pass — the same reason
        // isSuper() already bypasses inMyFacility() just above. Non-super
        // managers are still confined to their own org.
        && (isSuper() || incoming().organizationId == callerOrganization())
        && incoming().invitedBy == callerEmail()
        && incoming().status == 'pending'
        && canGrantRole(incoming().role)
        && inviteId == (incoming().facilityId + '--' + incoming().email);
      allow update: if isSignedIn() && resource.data.email == callerEmail()
        && resource.data.status == 'pending'
        && incoming().status == 'accepted'
        && incoming().email == resource.data.email
        && incoming().facilityId == resource.data.facilityId
        && incoming().organizationId == resource.data.organizationId
        && incoming().role == resource.data.role;
      allow update: if isManagerLevel() && inMyFacility(resource.data.facilityId)
        && incoming().status == 'revoked';
      // Re-issuing an invite (same email/facility invited again — e.g. after
      // a revoke, or by mistake) is a write to an ALREADY-EXISTING doc, so
      // Firestore evaluates it as an update, not a create — the create rule
      // above never applies here no matter which client API is used. Same
      // validation as create, so a manager can freely re-invite regardless
      // of the existing doc's prior status.
      allow update: if isManagerLevel()
        && isValidInvite(incoming())
        && inMyFacility(incoming().facilityId)
        && (isSuper() || incoming().organizationId == callerOrganization())
        && incoming().invitedBy == callerEmail()
        && incoming().status == 'pending'
        && canGrantRole(incoming().role)
        && inviteId == (incoming().facilityId + '--' + incoming().email);
      allow delete: if isManagerLevel() && inMyFacility(existing().facilityId);
    }

    // Departments: facility managers and above, only within their own facility.
    match /departments/{departmentId} {
      allow read: if isSuper() || resource.data.facilityId == callerFacility();
      allow create, update: if isFacilityLevel() && isValidId(departmentId) && isValidDepartment(incoming()) && inMyFacility(incoming().facilityId);
      allow delete: if isFacilityLevel() && inMyFacility(existing().facilityId);
    }

    // Workspace configuration is keyed by facility id, so the caller may only
    // read/write their own facility's config (super users: any).
    match /workspaceConfigs/{configId} {
      allow read: if isSuper() || configId == callerFacility();
      allow create, update, delete: if isFacilityLevel() && inMyFacility(configId);
    }

    // Staff registry: writes are department-head+ within their own facility,
    // OR a signed-in user self-onboarding their own general-member record
    // into an existing facility (see isSelfOnboardStaff above).
    match /staff/{staffId} {
      // isManagerLevel() (Supervisor/dept_head and above) always sees the
      // whole facility -- matches the write rules just below, which already
      // trust dept_head to create/update/delete staff, so restricting their
      // reads more tightly than their writes would be inconsistent and break
      // existing Supervisor capability. Below that (plain Member), reads are
      // scoped to the caller's own department -- a real server-side
      // boundary, not just the UI's "show one department at a time" toggle,
      // which was display-only and never stopped a direct API read of
      // another department's staff records.
      allow read: if isSuper()
        || (isManagerLevel() && resource.data.facilityId == callerFacility())
        || (isSignedIn() && resource.data.facilityId == callerFacility() && resource.data.departmentId == callerDepartment());
      allow create: if isManagerLevel() && isValidId(staffId) && isValidStaff(incoming()) && inMyFacility(incoming().facilityId);
      allow create: if isSignedIn() && isValidId(staffId) && isSelfOnboardStaff(incoming());
      allow update: if isManagerLevel() && isValidId(staffId) && isValidStaff(incoming()) && inMyFacility(incoming().facilityId);
      allow delete: if isManagerLevel() && inMyFacility(existing().facilityId);
    }

    // Roster cycles: department heads and above, within their own facility.
    match /cycles/{cycleId} {
      allow read: if isSuper() || resource.data.facilityId == callerFacility();
      allow create, update: if isManagerLevel() && isValidId(cycleId) && isValidCycle(incoming()) && inMyFacility(incoming().facilityId);
      allow delete: if isManagerLevel() && (isSuper() || inMyFacility(existing().facilityId));
    }

    // Task master templates: department heads and above, within their own facility.
    match /taskMasters/{taskMasterId} {
      allow read: if isSuper() || resource.data.facilityId == callerFacility();
      allow create, update: if isManagerLevel() && isValidId(taskMasterId) && isValidTaskMaster(incoming()) && inMyFacility(incoming().facilityId);
      allow delete: if isManagerLevel() && (isSuper() || inMyFacility(existing().facilityId));
    }

    match /test/{testId} {
      allow read: if true;
    }

    // --- OPERATIONAL DATA ---
    // Any signed-in user may write: staff complete tasks, submit timesheets,
    // and raise requests. No role-tier gate (unlike staff/cycles/taskMasters)
    // — but every write must stay within the caller's own facility, same as
    // every other collection's per-tenant isolation.
    match /dailyTasks/{taskId} {
      allow read: if isSuper() || resource.data.facilityId == callerFacility();
      allow create, update: if isSignedIn() && isValidId(taskId) && inMyFacility(incoming().facilityId);
      allow delete: if isSignedIn() && inMyFacility(existing().facilityId);
    }

    match /timesheets/{timesheetId} {
      // isManagerLevel() (Supervisor/dept_head and above) sees every
      // timesheet in the facility -- needed for payroll/approvals, and
      // matches the trust level already given to dept_head elsewhere (e.g.
      // canManageTasksAndApprovals on the client). Below that, a person may
      // only read their OWN timesheet -- matched via the staff doc's email
      // rather than a stored staffId-on-user field, so this applies to every
      // existing timesheet immediately with no backfill migration required.
      // Previously any signed-in person in the facility could read anyone
      // else's timesheet.
      allow read: if isSuper()
        || (isManagerLevel() && resource.data.facilityId == callerFacility())
        || (isSignedIn() && resource.data.facilityId == callerFacility()
            && get(/databases/$(database)/documents/staff/$(resource.data.staffId)).data.email == callerEmail());
      allow create, update: if isSignedIn() && isValidId(timesheetId) && inMyFacility(incoming().facilityId);
      allow delete: if isSignedIn() && inMyFacility(existing().facilityId);
    }

    match /approvals/{approvalId} {
      allow read: if isSuper() || resource.data.facilityId == callerFacility();
      allow create, update: if isSignedIn() && isValidId(approvalId) && inMyFacility(incoming().facilityId);
      allow delete: if isSignedIn() && inMyFacility(existing().facilityId);
    }

    match /extraHours/{extraHoursId} {
      allow read: if isSuper() || resource.data.facilityId == callerFacility();
      allow create, update: if isSignedIn() && isValidId(extraHoursId) && inMyFacility(incoming().facilityId);
      allow delete: if isSignedIn() && inMyFacility(existing().facilityId);
    }

    // Roster action items: created/toggled/removed by managers in the
    // roster grid; readable by anyone in the same facility so a future
    // staff-facing view doesn't need a rules change. Same per-tenant
    // isolation as everything else — facilityId must match the caller's.
    match /rosterActionItems/{itemId} {
      allow read: if isSuper() || resource.data.facilityId == callerFacility();
      allow create, update: if isManagerLevel() && isValidId(itemId) && isValidActionItem(incoming()) && inMyFacility(incoming().facilityId);
      allow delete: if isManagerLevel() && inMyFacility(existing().facilityId);
    }
  }
}
