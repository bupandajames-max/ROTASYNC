rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserEmail() {
      return request.auth.token.email;
    }

    // --- ROLE / SCOPE PRIMITIVES (Phase D enforcement) ---
    // The caller's tier lives in users/{uid} (written on login). Super users are
    // additionally recognized by email so seeding never depends on that doc.
    // NOTE: keep SUPER_EMAILS in sync with src/config/access.ts SUPERUSER_EMAILS.
    function callerEmail() {
      return isSignedIn() ? request.auth.token.email : '';
    }
    function isSuperEmail() {
      return callerEmail() in ['bupandajames@gmail.com'];
    }
    // Durable super-admin grants, managed in-app (see platformAdmins below).
    // isSuperEmail() stays only as the bootstrap path for the very first one.
    function isPlatformAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/platformAdmins/$(request.auth.uid));
    }
    function callerLevel() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accessLevel
        : 'staff';
    }
    // The facility this caller belongs to (from their role doc). Super users have none.
    function callerFacility() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.facilityId
        : '';
    }
    // Per-tenant write isolation: a non-super user may only write within their facility.
    function inMyFacility(fid) {
      return isSuper() || fid == callerFacility();
    }
    function isSuper() {
      return isSignedIn() && (isSuperEmail() || isPlatformAdmin() || callerLevel() == 'superuser');
    }
    function isFacilityLevel() {
      return isSignedIn() && (isSuper() || callerLevel() == 'facility_manager');
    }
    function isManagerLevel() {
      return isSignedIn() && (isFacilityLevel() || callerLevel() == 'dept_head');
    }

    // Standard string sanitization check to prevent path/injection poisoning
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Helper functions for collection schemas
    function isValidFacility(data) {
      return data.keys().hasAll(['id', 'name', 'location'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 150
        && data.location is string && data.location.size() <= 150
        // Org-defined classification (e.g. 'Branch', 'Warehouse', 'Primary Care')
        // — free text per workspace, not a fixed clinical enum.
        && (!data.keys().contains('facilitiesType') || (data.facilitiesType is string && data.facilitiesType.size() <= 100));
    }

    function isValidDepartment(data) {
      return data.keys().hasAll(['id', 'facilityId', 'name'])
        && data.id is string && data.id.size() <= 128
        && data.facilityId is string && data.facilityId.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 150;
    }

    function isValidStaff(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'role', 'facilityId'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 150
        && data.role is string && data.role.size() <= 100
        && data.facilityId is string && data.facilityId.size() <= 100;
    }

    function isValidCycle(data) {
      return data.keys().hasAll(['id', 'startDate', 'endDate', 'shifts'])
        && data.id is string && data.id.size() <= 128
        && data.startDate is string && data.startDate.size() <= 32
        && data.endDate is string && data.endDate.size() <= 32
        && data.shifts is map;
    }

    function isValidTaskMaster(data) {
      return data.keys().hasAll(['id', 'name', 'category', 'pattern', 'priority', 'frequency', 'active'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 150
        // Category is a dynamic, workspace-defined string (not a fixed clinical enum).
        && data.category is string && data.category.size() > 0 && data.category.size() <= 100
        && data.pattern in ['Shift-based', 'Role-group', 'Linked', 'Collab', 'Person-specific', 'Manager-assign', 'Dispensing-rotate', 'Auto']
        && data.priority in ['Critical', 'High', 'Standard', 'Routine']
        && data.frequency is string && data.frequency.size() <= 50
        && data.active is bool
        // Optional skill requirements, when present, must be a list.
        && (!data.keys().hasAny(['requiredSkills']) || data.requiredSkills is list);
    }

    function isValidSystemConfig(data) {
      return data.keys().hasAll(['id', 'seeded'])
        && data.id is string && data.id.size() <= 128
        && data.seeded is bool;
    }

    // Lightweight notes managers attach to a roster cell (see RosterActionItem).
    function isValidActionItem(data) {
      return data.keys().hasAll(['id', 'date', 'title', 'done', 'facilityId'])
        && data.id is string && data.id.size() <= 128
        && data.date is string && data.date.size() <= 32
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.done is bool
        && data.facilityId is string && data.facilityId.size() <= 100;
    }

    // --- COLLECTION RULES MATCH BLOCKS ---
    // Reads are open to any signed-in user (the app hydrates collections and
    // filters by facility/department client-side). Writes are role-gated.

    match /systemConfig/{configId} {
      allow read: if isSignedIn();
      allow create, update: if isManagerLevel() && isValidId(configId) && isValidSystemConfig(incoming());
      allow delete: if isManagerLevel();
    }

    // Role mirror — one doc per authenticated user, keyed by auth UID. This is
    // the doc callerLevel() reads, so it's the actual privilege choke point:
    // a user may always write their OWN doc at 'staff' (the safe default),
    // but may not self-escalate beyond that. Re-affirming a level already on
    // the doc is allowed (so an already-legitimately-elevated user's own
    // hydration write doesn't break); moving a level UP for yourself is not.
    // Granting someone a higher tier is a separate write performed by an
    // existing manager-level+ user, targeting that OTHER person's doc.
    match /users/{userId} {
      // Always allowed to read your own doc (needed before facilityId is even
      // known, e.g. right after first sign-in). Otherwise scoped to managers
      // reading within their own facility, or super users reading any.
      allow read: if isSignedIn() && (request.auth.uid == userId || isSuper()
        || (isManagerLevel() && resource.data.facilityId == callerFacility()));
      allow create: if isSignedIn() && request.auth.uid == userId
        && (incoming().accessLevel == 'staff' || isSuperEmail() || isPlatformAdmin());
      allow update: if isSignedIn() && request.auth.uid == userId
        && (incoming().accessLevel == 'staff' || incoming().accessLevel == existing().accessLevel || isSuperEmail() || isPlatformAdmin());
      allow update: if isSignedIn() && request.auth.uid != userId
        && isManagerLevel() && inMyFacility(incoming().facilityId);
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // Durable super-admin grants — one doc per platform admin, keyed by their
    // uid. Only an existing super user (email-bootstrapped or already a
    // platform admin) can grant/revoke another. This is what lets adding an
    // admin be an in-app action instead of a source-code change + redeploy.
    match /platformAdmins/{adminUid} {
      allow read: if isSuper();
      allow create, delete: if isSuper();
    }

    // Facilities (sites): readable only by members of that facility (or
    // super users) — not by any signed-in stranger. Writes remain super-only.
    match /facilities/{facilityId} {
      allow read: if isSuper() || facilityId == callerFacility();
      allow create, update: if isSuper() && isValidId(facilityId) && isValidFacility(incoming());
      allow delete: if isSuper();
    }

    // Departments: facility managers and above, only within their own facility.
    match /departments/{departmentId} {
      allow read: if isSuper() || resource.data.facilityId == callerFacility();
      allow create, update: if isFacilityLevel() && isValidId(departmentId) && isValidDepartment(incoming()) && inMyFacility(incoming().facilityId);
      allow delete: if isFacilityLevel() && inMyFacility(existing().facilityId);
    }

    // Workspace configuration is keyed by facility id, so the caller may only
    // read/write their own facility's config (super users: any).
    match /workspaceConfigs/{configId} {
      allow read: if isSuper() || configId == callerFacility();
      allow create, update, delete: if isFacilityLevel() && inMyFacility(configId);
    }

    // Staff registry: department heads and above, only within their own facility.
    match /staff/{staffId} {
      allow read: if isSuper() || resource.data.facilityId == callerFacility();
      allow create, update: if isManagerLevel() && isValidId(staffId) && isValidStaff(incoming()) && inMyFacility(incoming().facilityId);
      allow delete: if isManagerLevel() && inMyFacility(existing().facilityId);
    }

    // Roster cycles: department heads and above, within their own facility.
    match /cycles/{cycleId} {
      allow read: if isSuper() || resource.data.facilityId == callerFacility();
      allow create, update: if isManagerLevel() && isValidId(cycleId) && isValidCycle(incoming()) && inMyFacility(incoming().facilityId);
      allow delete: if isManagerLevel() && (isSuper() || inMyFacility(existing().facilityId));
    }

    // Task master templates: department heads and above, within their own facility.
    match /taskMasters/{taskMasterId} {
      allow read: if isSuper() || resource.data.facilityId == callerFacility();
      allow create, update: if isManagerLevel() && isValidId(taskMasterId) && isValidTaskMaster(incoming()) && inMyFacility(incoming().facilityId);
      allow delete: if isManagerLevel() && (isSuper() || inMyFacility(existing().facilityId));
    }

    match /test/{testId} {
      allow read: if true;
    }

    // --- OPERATIONAL DATA ---
    // Any signed-in user may write: staff complete tasks, submit timesheets,
    // and raise requests. No role-tier gate (unlike staff/cycles/taskMasters)
    // — but every write must stay within the caller's own facility, same as
    // every other collection's per-tenant isolation.
    match /dailyTasks/{taskId} {
      allow read: if isSuper() || resource.data.facilityId == callerFacility();
      allow create, update: if isSignedIn() && isValidId(taskId) && inMyFacility(incoming().facilityId);
      allow delete: if isSignedIn() && inMyFacility(existing().facilityId);
    }

    match /timesheets/{timesheetId} {
      allow read: if isSuper() || resource.data.facilityId == callerFacility();
      allow create, update: if isSignedIn() && isValidId(timesheetId) && inMyFacility(incoming().facilityId);
      allow delete: if isSignedIn() && inMyFacility(existing().facilityId);
    }

    match /approvals/{approvalId} {
      allow read: if isSuper() || resource.data.facilityId == callerFacility();
      allow create, update: if isSignedIn() && isValidId(approvalId) && inMyFacility(incoming().facilityId);
      allow delete: if isSignedIn() && inMyFacility(existing().facilityId);
    }

    match /extraHours/{extraHoursId} {
      allow read: if isSuper() || resource.data.facilityId == callerFacility();
      allow create, update: if isSignedIn() && isValidId(extraHoursId) && inMyFacility(incoming().facilityId);
      allow delete: if isSignedIn() && inMyFacility(existing().facilityId);
    }

    // Roster action items: created/toggled/removed by managers in the
    // roster grid; readable by anyone in the same facility so a future
    // staff-facing view doesn't need a rules change. Same per-tenant
    // isolation as everything else — facilityId must match the caller's.
    match /rosterActionItems/{itemId} {
      allow read: if isSuper() || resource.data.facilityId == callerFacility();
      allow create, update: if isManagerLevel() && isValidId(itemId) && isValidActionItem(incoming()) && inMyFacility(incoming().facilityId);
      allow delete: if isManagerLevel() && inMyFacility(existing().facilityId);
    }
  }
}
