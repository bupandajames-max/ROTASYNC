# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# RESEND_API_KEY: Optional. Enables invite EMAIL notifications via Resend
# (https://resend.com — free tier available). Get a key, add it here, and
# invite emails start sending automatically. If unset, invites still work
# fully in-app (the Firestore invite record is the source of truth for
# access); only the courtesy email is skipped.
RESEND_API_KEY=""

# VITE_ENABLE_DEMO_PREVIEW: Optional. When "true", shows the "just exploring?"
# preview buttons on the public sign-in page (drop into a read/edit session
# with no sign-in — useful for sales demos). OFF by default in production so
# real external users can ONLY enter via Google sign-in + an invite. Always
# on in local dev regardless of this flag.
VITE_ENABLE_DEMO_PREVIEW=""

# INVITE_FROM_EMAIL: Optional. The "From" address for invite emails, e.g.
# "Acme Rosters <invites@yourdomain.com>". Must be a domain/sender verified
# in your Resend account. Defaults to Resend's shared "onboarding@resend.dev"
# sender, which works out of the box for testing.
INVITE_FROM_EMAIL=""
